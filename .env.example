# NexLog environment variables
# Copy to .env for local development. Never commit .env.

# REST API authentication
# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
NEXLOG_API_KEY=

# Optional intelligence enrichment
ABUSEIPDB_API_KEY=
GEOIP_DB_PATH=

# Fast/offline defaults
NEXLOG_HARDWARE_MODE=adaptive
NEXLOG_PROFILE=balanced
NEXLOG_MAX_WORKERS=2
NEXLOG_BATCH_SIZE=5000
NEXLOG_MAX_MEMORY_MB=2048
NEXLOG_MAX_CPU_PERCENT=75
NEXLOG_MAX_LINE_BYTES=1048576
NEXLOG_GPU_GUI=auto
NEXLOG_AI_EMBEDDER=fast
NEXLOG_VECTOR_STORE=numpy
NEXLOG_LLM_FORCE_TIER=3
NEXLOG_WORKSPACE_DIR=

# Optional higher-quality AI
# NEXLOG_AI_EMBEDDER=semantic
# NEXLOG_VECTOR_STORE=chroma
# NEXLOG_ENABLE_HEAVY_AI=1

# Optional AI providers. Prefer provider slots for new installs.
OLLAMA_HOST=http://localhost:11434
NEXLOG_MODEL=mistral
NEXLOG_AI_PROVIDER_1=
NEXLOG_AI_KEY_1=
NEXLOG_AI_ENDPOINT_1=
NEXLOG_AI_MODEL_1=auto-latest
NEXLOG_AI_PROVIDER_2=
NEXLOG_AI_KEY_2=
NEXLOG_AI_ENDPOINT_2=
NEXLOG_AI_MODEL_2=auto-latest
NEXLOG_MANAGED_AI_ENDPOINT=
NEXLOG_MANAGED_AI_TOKEN=

# Legacy provider aliases still work for compatibility.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional GUI visuals
# Set to 1 to enable live screen-capture glass blur.
NEXLOG_ENABLE_GLASS=0
