# NexLog web/API secrets and AI provider settings.
# Copy to .env.web for the FastAPI server. Browser code never receives these.

NEXLOG_WEB_API_KEY=change-me-before-team-use
NEXLOG_WEB_AI_PROVIDER_1=
NEXLOG_WEB_AI_KEY_1=
NEXLOG_WEB_AI_ENDPOINT_1=
NEXLOG_WEB_AI_MODEL_1=auto-latest
NEXLOG_WEB_AI_PROVIDER_2=
NEXLOG_WEB_AI_KEY_2=
NEXLOG_WEB_AI_ENDPOINT_2=
NEXLOG_WEB_AI_MODEL_2=auto-latest
NEXLOG_WEB_OLLAMA_HOST=http://127.0.0.1:11434
NEXLOG_WEB_MODEL=
NEXLOG_MANAGED_AI_ENDPOINT=
NEXLOG_MANAGED_AI_TOKEN=
